# Kraken API credentials
# Get from: https://www.kraken.com/u/security/api
# NOT required for paper trading — only needed for live mode
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# OpenAI API key — required for the AI analysis layer
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# TAAPI.IO provider indicators — optional but recommended for richer external technical data
# Get from: https://taapi.io/
TAAPI_SECRET=
TAAPI_EXCHANGE=binance
TAAPI_SYMBOL=BTC/USDT
TAAPI_INTERVAL=1m
TAAPI_REFRESH_SEC=60

# Live margin shorts: set to "true" only after Kraken margin/borrow is enabled (otherwise live shorts are blocked)
# KRAKEN_ENABLE_MARGIN_SHORT=false

# Trading mode: "live" or "paper"
TRADING_MODE=paper

# Log level: "trace" | "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# Starting account equity (USD) — used by the web dashboard to compute balance
# Defaults to 1000 (paper trading default) if not set
STARTING_EQUITY=1000

# SQLite path override (optional). Default is <monorepo root>/data/trading-bot.db when unset.
# DB_PATH=/absolute/path/to/trading-bot.db
